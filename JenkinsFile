pipeline {
agent any
tools {
maven 'Maven'
jdk 'jdk'
}
stages {
stage('Checkout') {
steps {
git branch: ‘main’, url: 'https://github.com/rishikaa-03/my-maven-app.git'
}
}
stage('Build') {
steps {
sh 'mvn clean package'
}
}
stage('Test') {
steps {
sh 'mvn test'
}
}
stage('Run Application') {
steps {
// Start the JAR application
sh 'java -jar target/MyMavenApp-1.0-SNAPSHOT.jar'
}
}
}
post {
success {
echo 'Build and deployment successful!'
}
failure {
echo 'Build failed!'
}
}
}
